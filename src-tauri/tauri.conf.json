{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DLL Icon Forge",
  "version": "0.1.0",
  "identifier": "it.valeriogc.dlliconforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DLL Icon Forge",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src ipc: http://ipc.localhost http: https:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/dll-icon-forge/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Italian"],
        "displayLanguageSelector": true,
        "template": "./installer-template.nsi"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
